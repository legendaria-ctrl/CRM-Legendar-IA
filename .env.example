# Copia este archivo como .env (local) y configura las mismas variables
# en Vercel → Settings → Environment Variables para producción.

# Firebase (Project settings → General → Tus apps → Config del SDK)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Claves de acceso compartidas por rol (defínelas tú, no dejes las de ejemplo)
ADMIN_PASSCODE=
VENDEDOR_PASSCODE=

# Secreto para firmar la cookie de sesión (genera uno propio y no lo compartas)
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Clave compartida para que otro CRM consulte /api/clientes/existe (header x-api-key)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLIENTES_API_KEY=

# Webhook de Skool (Plugins > Webhook del grupo) para invitar automáticamente
# a la comunidad al marcar "Invitación enviada" en el CRM.
SKOOL_WEBHOOK_URL=
